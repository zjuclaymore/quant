"""
核心回测引擎逻辑模块 (Backtest Core Logic Module)

本模块以 Mixin 模式提供了单因子回测的核心算法逻辑。通过将回测流程分解为多个原子化的私有方法，
实现了从原始因子导出、数据清洗、可选中性化接入到模拟交易和绩效评价的完整工作流。

核心特性:
    - 向量化处理: 尽可能利用 Pandas 和 Numpy 的向量化操作减少显式循环，提升大规模数据处理效率。
    - 组合模式: 采用 Mixin 类 `BacktestCoreMixin` 设计，方便与 `SingleFactorBacktesterV2` 引擎解耦与组合。
    - 工业级清洗: 支持 MAD 去极值与 Z-Score 标准化；中性化可在外部预处理后输入。
    - 实战化仿真: 模拟真实的月度换仓逻辑，考虑了 VWAP 撮合、涨跌停限制、以及延迟卖出等实盘交易细节。

数学公式参考:
    1. MAD 去极值:
       设因子序列为 X，中位数为 M，绝对偏差中位数为 MAD = median(|X - M|)
       则截断边界为 [M - n*MAD, M + n*MAD]，通常 n=3。
    2. 中性化回归 (可选):
       Factor = α + β1 * ln(MV) + Σ(γ_i * Industry_i) + ε
       中性化后的因子即为残差项 ε，其代表了剔除市值和行业暴露后的纯净因子收益贡献。
"""

import numpy as np
import pandas as pd
from scipy.stats import spearmanr, pearsonr

from back_test.sigle_factor_test.src.bt_utils import (
    add_card_to_html,
    build_report_header,
    write_report_html,
    compute_backtest_kpis,
    generate_all_charts,
    build_workflow_pipeline,
    cross_section_mad_normalize,
    neutralize_factor,
)


class BacktestCoreMixin:
    """
    单因子回测核心逻辑混入类 (Backtest Core Logic Mixin)

    该类不应单独实例化，而是作为 `SingleFactorBacktesterV2` 的父类使用，提供核心回测驱动能力。
    它定义了标准的单因子回测流水线，涵盖了从原始信号到最终 KPI 报告的所有必要步骤。

    主要工作流程 (Pipeline):
        1.  数据对齐: 统一因子、行情、辅助数据的日期格式与代码标准。
        2.  静态过滤: 剔除北交所股票及其他非必要标的。
        3.  市值预处理: 关联截面市值，并执行“微盘股剔除”(默认剔除截面后 20% 股票)。
        4.  行业投影: 根据申万 2021 分类对各期标的进行行业标签关联。
        5.  截面标准化:
            - MAD 去极值: 防止极端离群值扭曲回归结果。
            - Z-Score 标准化: 将不同量级的因子值转化到同一尺度。
        6.  中性化处理 (可选): 默认不在本模块内执行，可接入外部预处理结果。
        7.  因子分组: 支持标准的 10 分组 (qcut) 或固定数量 (group_size) 分组。
        8.  模拟调仓: 逐月执行模拟买卖，精确处理涨跌停导致的任务延迟。
        9.  绩效评估: 计算各组收益曲线、多空对冲净值、IC/RankIC 序列以及一系列风险指标。
        10. 研报生成: 自动产出可视化 HTML 报告和数据导出。
    """

    def _merge_industry_data(self, df1):
        """
        为因子截面数据追加当期申万行业分类 (SW Industries)

        逻辑说明:
            1. 根据回测框架加载的行业映射表 `self.ind_df`，遍历截面的每个 `year_month`。
            2. 对每个月份，筛选该日期处于“纳入日期”与“剔除日期”之间的有效行业记录。
            3. 若同标的存在多条记录（常见于分类调整），取“纳入日期”最近的一条（Drop Duplicates）。
            4. 将行业代码映射至 `df1` 的 `industry` 列。

        参数:
            df1 (pd.DataFrame): 包含 ['symbol', 'year_month'] 等列的因子截面数据。

        返回:
            pd.DataFrame: 合并行业列后的 DataFrame。若无有效行业数据，则返回原对象。
        """
        if getattr(self, "ind_df", None) is None or self.ind_df.empty:
            return df1
            
        ind = self.ind_df.copy()
        ind['纳入日期'] = pd.to_datetime(ind['纳入日期'])
        ind['剔除日期'] = pd.to_datetime(ind['剔除日期'].fillna('20991231'))
        
        res_dfs = []
        for ym, group in df1.groupby('year_month'):
            ym_dt = ym.to_timestamp() if hasattr(ym, 'to_timestamp') else pd.to_datetime(ym)
            active = ind[(ind['纳入日期'] <= ym_dt) & (ind['剔除日期'] >= ym_dt)]
            active = active.sort_values('纳入日期', ascending=False).drop_duplicates('S_INFO_WINDCODE')
            
            merged = pd.merge( group,
                               active[['S_INFO_WINDCODE', 'SW_IND_CODE']].rename(columns={'S_INFO_WINDCODE': 'symbol', 'SW_IND_CODE': 'industry'}),
                               on='symbol',
                               how='left' )
            res_dfs.append(merged)
            
        return pd.concat(res_dfs, ignore_index=True) if res_dfs else df1

    def run_backtest(
        self,
        factor_name: str,
        factor_df: pd.DataFrame,
        source_factor_col: str = None,
        start_month="2000-01",
        end_month="2025-12",
        mv_df: pd.DataFrame = None,
        commission=0.0015,
        direction="auto",
        benchmark_symbol="000905.SH",
        group_size: int = 0,
    ):
        """
        执行单因子回测主执行器 (The Main Backtest Runner)

        此方法作为整个回测任务的顶层入口，按序驱动十大核心步骤。它不直接处理复杂的循环计算，
        而是调度各个私有方法执行具体的任务，并最终汇总生成回测报告。

        调用示例:
            >>> engine = SingleFactorBacktesterV2(df_daily, out_dir="output/test")
            >>> engine.run_backtest(
            ...     factor_df=my_factor_data,
            ...     factor_name="target_factor",
            ...     start_month="2020-01",
            ...     end_month="2023-12",
            ...     enable_ind_neu=True
            ... )

        参数详细说明:
            factor_name (str): 
                因子列名。脚本会自动搜索以此命名的列作为信号来源。
            factor_df (pd.DataFrame): 
                核心因子数据。必须包含 `date` (或其变体), `symbol` 及因子值列。支持长表格式。
            start_month (str, 默认 '2000-01'): 
                回测起始月份，格式为 'YYYY-MM'。回测会在该月底产生第一个信号，次月初交易。
            end_month (str, 默认 '2025-12'): 
                回测结束月份。确定回测的时间终点。
            mv_df (pd.DataFrame, 可选): 
                市值数据。用于执行微盘股过滤；若外部做了中性化，也可作为控制变量来源。
            commission (float, 默认 0.0015): 
                单边总费率 (包含佣金、印花税、过户费等)。交易摩擦将从每期收益率中直接扣除。
            direction (str 或 int, 默认 'auto'): 
                因子多空方向。
                - 'auto': 根据 G1 与 G10 的全期累计净值自动判定。
                - 1: 判定因子值为正相关 (因子值越大，未来收益越高)。
                - -1: 判定因子值为负相关 (因子值越小，未来收益越高)。
            benchmark_symbol (str, 默认 '000905.SH'): 
                基准指数代码。脚本从 `index_daily_dir` 寻找对应 pickle 文件计算超额收益。
            group_size (int, 默认 0): 
                分组策略。
                - 0: 采用 10 分组 (Deciles) 均分。
                - >0: 每组固定持有 `group_size` 个股票（通常用于高频、小盘或特定头寸测试）。

        返回:
            None: 结果将持久化至 `self.out_dir`，通过日志、HTML 报告和 CSV 文件呈现。
        """
        self.logger.info(
            f"[{factor_name}] (V2.5) 开始优化回测 (区间: {start_month} 至 {end_month})"
        )
        html_parts = []

        # ============ 1. 因子数据对齐 ============
        df1 = self._align_factor(factor_df, factor_name)

        # ============ 2. 市值关联 ============
        df1 = self._merge_market_value(df1, mv_df)

        # ============ 2.5 行业关联 ============
        df1 = self._merge_industry_data(df1)
        has_industry = "industry" in df1.columns

        if factor_name not in df1.columns:
            possible = [
                c for c in df1.columns
                if c not in ["date", "symbol", "year_month", "level1_name", "lncap", "industry"]
            ]
            factor_name = possible[0]
            
        keep_cols = ["year_month", "symbol", factor_name, "lncap"]
        if has_industry: keep_cols.append("industry")
        df1 = df1[keep_cols]

        # ============ 3. MAD + Z-score + 中性化 ============
        try:
            df1[factor_name] = df1.groupby("year_month")[factor_name].transform(
                lambda x: cross_section_mad_normalize(x, 3.0)
            )
            self.logger.info("已执行截面 MAD去极值与 Z-Score 标准化")

            ind_col = "industry" if has_industry else None
            neu_result = neutralize_factor(
                df1,
                factor_name,
                "lncap",
                ind_col=ind_col,
                logger=self.logger,
            )
            df1[f"{factor_name}_neu"] = neu_result[0] if isinstance(neu_result, tuple) else neu_result
            ind_msg = "包含行业维度" if has_industry else "仅含市值维度"
            self.logger.info(f"已完成因子中性化 ({ind_msg})")
        except Exception as e:
            self.logger.error(f"标准化与中性化过程中发生错误: {e}", exc_info=True)
            raise

        target_factor = f"{factor_name}_neu"

        # ============ 3.5 股票池提前筛查 (避免分组污染) ============
        cal = self.df_calendar[
            (self.df_calendar["year_month"] >= start_month)
            & (self.df_calendar["year_month"] <= end_month)
        ].copy()

        # ============ 3.5 收集因子覆盖度信息 ============
        # 覆盖度同时保留「全样本」与「交易池」两种口径，便于报告页对比。
        def _build_coverage_records(frame):
            records = []
            for _, row in cal.iterrows():
                ym = row["year_month"]
                t_buy = row["buy_date"]
                market_snap = self.limit_df[self.limit_df["date"] == t_buy]
                market_count = len(market_snap)
                factor_snap = frame[frame["year_month"] == ym]
                factor_count = factor_snap[factor_name].notna().sum()
                coverage = factor_count / market_count if market_count > 0 else 0
                records.append({
                    "year_month": ym,
                    "date": t_buy,
                    "factor_count": int(factor_count),
                    "market_count": int(market_count),
                    "coverage": float(coverage),
                })
            return pd.DataFrame(records)

        df_coverage_all = _build_coverage_records(df1)
        df_coverage_all_cs = df_coverage_all.copy()

        df1 = self._apply_stock_pool_filter(df1, cal)

        df_coverage_tradeable = _build_coverage_records(df1)
        df_coverage_tradeable_cs = df_coverage_tradeable.copy()

        # ============ 4. 分组 ============
        df1, n_groups = self._assign_groups(df1, target_factor, group_size)

        # ============ 5. 调仓循环 ============

        self.logger.info(
            f"开始处理历史交割 (共 {len(cal)} 期, 交易摩擦: {commission:.2%})..."
        )

        holding_period_returns, ic_records = self._run_trading_loop(
            df1, cal, target_factor, commission
        )

        if not holding_period_returns:
            self.logger.error("回测期间无有效交易记录!")
            return

        # ============ 6. 各组等权表现计算 ============
        df_trades, grouped_returns, market_returns, init_ym = (
            self._compute_group_returns(holding_period_returns)
        )

        self.logger.info("各分组算术收益聚合及全市场基准推演完成")

        # ============ 7. 方向自动判定 ============
        max_group = df_trades["group"].max()
        best_g, worst_g, direction = self._detect_direction(
            grouped_returns, max_group, direction
        )

        best_df = grouped_returns[grouped_returns["group"] == best_g].copy()
        worst_df = grouped_returns[grouped_returns["group"] == worst_g].copy()

        # ============ 8. 基准对齐 ============
        df_bench_m = self._load_benchmark_returns(
            benchmark_symbol, start_month, end_month, cal
        )
        best_df = self._align_benchmark(best_df, df_bench_m)
        worst_df = self._align_benchmark(worst_df, df_bench_m)

        # ============ 9. 计算 KPI ============
        df_ic = pd.DataFrame(ic_records)
        n_total_symbols = self.df_daily["symbol"].nunique()

        kpis = compute_backtest_kpis(
            best_df, worst_df, df_trades, df_ic, market_returns,
            cal, best_g, worst_g, df1, n_total_symbols,
        )

        # ============ 10. HTML 报告 ============
        self._build_report(
            html_parts, factor_name, factor_df, df1,
            best_df, worst_df, grouped_returns, df_trades,
            market_returns, df_ic, cal, kpis,
            best_g, worst_g, max_group, commission,
            start_month, end_month, delay_days=0,
            df_coverage_all=df_coverage_all,
            df_coverage_tradeable=df_coverage_tradeable,
            df_coverage_all_cs=df_coverage_all_cs,
            df_coverage_tradeable_cs=df_coverage_tradeable_cs,
            df1_all=df1,
            source_factor_col=source_factor_col,
        )

    # ------------------------------------------------------------------
    # run_backtest 内部子步骤 (私有方法)
    # ------------------------------------------------------------------

    def _align_factor(self, factor_df, factor_name):
        """
        步骤1: 因子数据预处理与对齐

        逻辑说明:
            1. 规范化列名: 将含有 'date' 或 '日期' 的列统一重命名为 'date'，将含有 'code' 或 'symbol' 的列命名为 'symbol'。
            2. 数据清洗: 剔除北交所股票 (BJ)，因其流动性与结算制度与深沪市场差异较大。
            3. 月度截断: 回测基于月度频率，取每个股票在每个自然月内最后一条有效的因子记录。
            4. 时间窗口: 该方法确保信号日期位于月底，为次月初的模拟交易提供决策依据。

        参数:
            factor_df (pd.DataFrame): 原始因子长表。
            factor_name (str): 目标因子值列名。

        返回:
            pd.DataFrame: 对齐后的月度截面数据。
        """
        df1 = factor_df.copy()
        for c in df1.columns:
            if "date" in c.lower() or "日期" in c.lower():
                df1.rename(columns={c: "date"}, inplace=True)
            if "code" in c.lower() or "symbol" in c.lower():
                df1.rename(columns={c: "symbol"}, inplace=True)
        df1["date"] = pd.to_datetime(df1["date"].astype(str))
        df1 = df1[~df1["symbol"].str.endswith(".BJ")]
        df1["year_month"] = df1["date"].dt.to_period("M")
        df1 = df1.groupby(["symbol", "year_month"]).last().reset_index()
        return df1

    def _merge_market_value(self, df1, mv_df):
        """
        步骤2: 关联市值数据并执行“微盘股剔除”

        逻辑说明:
            1. 数据对齐: 将输入的市值数据同步重命名列名，并按月度频率取月末值。
            2. 截面合并: 通过 ['symbol', 'year_month'] 将市值数据 `lncap` 右连接至因子表。
            3. 微盘股剔除: 计算当期截面内市值的滚动百分比排名，剔除市值最小的后 20% 标的。
               理论依据: 微盘股在量化投资中存在较大的冲击成本和流动性溢价，剔除可提高回测的实战参考价值。

        参数:
            df1 (pd.DataFrame): 因子截面数据。
            mv_df (pd.DataFrame): 市值辅助数据。

        返回:
            pd.DataFrame: 过滤微盘股并含市值列的数据集。
        """
        if mv_df is not None and not mv_df.empty:
            mv = mv_df.copy()
            for c in mv.columns:
                if "date" in c.lower() or "日期" in c.lower():
                    mv.rename(columns={c: "date"}, inplace=True)
                if "code" in c.lower() or "symbol" in c.lower():
                    mv.rename(columns={c: "symbol"}, inplace=True)
            mv["date"] = pd.to_datetime(mv["date"].astype(str))
            mv["year_month"] = mv["date"].dt.to_period("M")
            mv = mv.groupby(["symbol", "year_month"]).last().reset_index()
            mv_col = [
                c for c in mv.columns if c not in ["date", "symbol", "year_month"]
            ][0]
            mv = mv[["year_month", "symbol", mv_col]].rename(columns={mv_col: "lncap"})
            df1 = pd.merge(df1, mv, on=["year_month", "symbol"], how="left")

            df1["_mv_pct"] = df1.groupby("year_month")["lncap"].transform(
                lambda x: x.rank(pct=True)
            )
            df1 = df1[df1["_mv_pct"] > 0.20].drop(columns=["_mv_pct"])
            self.logger.info("已完成市值对数提取, 并于每期截面剔除市值后 20% 的微盘股")
        else:
            self.logger.warning("未提供市值因子数据, 市值过滤环节效果受限")
            df1["lncap"] = 1.0
        return df1

    def _get_strict_liq_symbols(self, t_buy):
        """返回在买入日通过严格流动性筛选的股票集合。"""
        liq_snap = self.liq_df[self.liq_df["date"] == t_buy]
        if liq_snap.empty:
            return set()

        liq_snap = liq_snap[liq_snap["valid_days_20"] >= 15]
        if liq_snap.empty:
            return set()

        vol_threshold = liq_snap["avg_vol_20"].quantile(0.10)
        liq_snap = liq_snap[liq_snap["avg_vol_20"] >= vol_threshold]
        return set(liq_snap["symbol"].astype(str).tolist())

    def _apply_stock_pool_filter(self, df1, cal):
        """
        步骤 3.5: 细粒度股票池筛查与流动性预检

        在因子排序分组之前，执行严谨的实战生存检查。若股票在预定买入日无法正常开仓，则不应参与当期的分组贡献。

        检查项:
            1. 流动性验证: 查询预定义的 `self.liq_df`。要求过去 20 个交易日中至少有 15 天有成交量，
               且当前截面的平均成交量不能处于全市场的末尾 10% (剔除僵尸股)。
            2. 信号连贯性: 确保信号日期与调仓日历匹配。

        参数:
            df1 (pd.DataFrame): 已完成预处理的备选池数据。
            cal (pd.DataFrame): 调仓日历，确定预定买入日。

        返回:
            pd.DataFrame: 经过流动性筛选后的干净因子池。
        """
        filtered_dfs = []
        for _, row in cal.iterrows():
            ym = row["year_month"]
            t_buy = row["buy_date"]

            signal_df = df1[df1["year_month"] == ym].copy()
            if signal_df.empty:
                continue

            # --- 流动性提前筛选 ---
            valid_liq = self._get_strict_liq_symbols(t_buy)
            if valid_liq:
                signal_df = signal_df[signal_df["symbol"].isin(valid_liq)]
            else:
                signal_df = signal_df.iloc[0:0]

            # --- ST 过滤 ---
            # (如果开启了 --enable-st-filter，self.st_df 已经合并到 df1 还是单独查？)
            # 根据现有框架，原先 ST 过滤也是直接用 mask 来做的，现在可以在这里结合。
            # 为了严谨，现在只转移基础的流动性。

            filtered_dfs.append(signal_df)
        
        if not filtered_dfs:
            return pd.DataFrame(columns=df1.columns)
            
        return pd.concat(filtered_dfs, ignore_index=True)

    def _assign_groups(self, df1, target_factor, group_size):
        """
        步骤4: 截面因子分组计算

        将全市场标的根据因子得分进行从低到高的排序并分配组号。

        分组逻辑:
            - 若 `group_size == 0`: 采用等分分位数法 (qcut)，将有效标的均分为 10 组 (G1~G10)。
            - 若 `group_size > 0`: 采用固定数量法，按因子排名每 `group_size` 个股票分为一组。
            - 排序方法: `rank(method="first")` 确保在因子值相同时分配唯一的排名，避免分组倾斜。

        参数:
            df1 (pd.DataFrame): 已过滤标的数据。
            target_factor (str): 用于排序的列名。
            group_size (int): 每组数量配置。

        返回:
            tuple: (带 group 列的 DataFrame, 总分组数 n_groups)
        """
        df1[target_factor] = pd.to_numeric(df1[target_factor], errors="coerce")
        if df1[target_factor].notna().sum() == 0:
            raise ValueError(
                f"分组失败: 因子列 {target_factor} 全为空值。"
                "请检查因子数据是否加载正确，或过滤条件是否过严。"
            )
        if group_size > 0:
            def _group_fixed(x):
                if x.notna().sum() == 0:
                    return pd.Series(np.nan, index=x.index)
                return (x.rank(method="first") - 1) // group_size + 1

            df1["group"] = df1.groupby("year_month")[target_factor].transform(_group_fixed)
            if df1["group"].notna().sum() == 0:
                raise ValueError(
                    "分组失败: 所有月份均无有效分组。"
                    "请检查因子值、过滤条件或样本覆盖度。"
                )
            n_groups = df1["group"].max()
            if pd.isna(n_groups):
                raise ValueError(
                    "分组失败: 未能得到有效分组数。"
                    "请检查因子值与过滤条件。"
                )
            df1["group"] = df1["group"].astype(int)
            n_groups = int(n_groups)
            self.logger.info(f"按每组 {group_size} 只股票分组, 实际分组数: {n_groups}")
        else:
            def _group_qcut(x):
                n = x.notna().sum()
                if n == 0:
                    return pd.Series(np.nan, index=x.index)
                q = min(10, n)
                try:
                    return pd.qcut(
                        x.rank(method="first"),
                        q,
                        labels=False,
                        duplicates="drop",
                    ) + 1
                except Exception:
                    return pd.Series(np.nan, index=x.index)

            df1["group"] = df1.groupby("year_month")[target_factor].transform(_group_qcut)
            if df1["group"].notna().sum() == 0:
                raise ValueError(
                    "分组失败: 所有月份均无有效分组。"
                    "请检查因子值、过滤条件或样本覆盖度。"
                )
            n_groups = df1["group"].max()
            if pd.isna(n_groups):
                raise ValueError(
                    "分组失败: 未能得到有效分组数。"
                    "请检查因子值与过滤条件。"
                )
            n_groups = int(n_groups)
            self.logger.info(f"按固定 10 组均分, 实际有效分组数: {n_groups}")
        return df1, n_groups

    def _run_trading_loop(self, df1, cal, target_factor, commission):
        """
        步骤5: 调仓循环仿真引擎 (Trading Simulator Loop)

        该核心方法逐月模拟投资者的调仓行为，精确保现实战中的成交限制。

        仿真细节:
            1. 买入撮合: 在 `buy_date` (通常是次月初第一个交易日) 以 **VWAP** 价格等权买入。
               若当日一字涨停，则该标的无法开仓，从当期组合中剔除。
            2. 卖出撮合: 在 `sell_date` (通常是月底最后一个交易日) 以 **VWAP** 价格清仓。
            3. 复权处理: 收益计算使用 `adj_vwap` (根据累计复权因子调整后的 VWAP)，确保穿越除权除息。
            4. 异常处理: 自动识别一字跌停导致的无法卖出，并触发 `_handle_delayed_sells` 逻辑。
            5. IC 计算: 同步计算因子得分与当期持有期真实收益的相关性 (IC / RankIC)。

        参数:
            df1 (pd.DataFrame): 携带分组信息的因子表。
            cal (pd.DataFrame): 调仓日历。
            target_factor (str): 目标因子列。
            commission (float): 单边费率。

        返回:
            tuple: (各期交易详情 DataFrame 列表, 逐期 IC 记录列表)
        """
        holding_period_returns = []
        ic_records = []

        for _, row in cal.iterrows():
            ym = row["year_month"]
            t_buy = row["buy_date"]
            t_sell = row["sell_date"]

            signal_df = df1[df1["year_month"] == ym].copy()
            if signal_df.empty:
                continue

            # 分组和交易统一使用同一严格流动性口径
            valid_liq = self._get_strict_liq_symbols(t_buy)
            if valid_liq:
                signal_df = signal_df[signal_df["symbol"].isin(valid_liq)]
            else:
                continue

            # --- 买入 (以 VWAP 均价撮合) ---
            buy_mask = self._get_trade_mask([t_buy])
            buy_mask = buy_mask[buy_mask["symbol"].isin(valid_liq)]
            valid_buys = buy_mask[~buy_mask["is_limit_up"]].copy()
            # 计算复权 VWAP: adj_vwap = vwap * (adj_close / close)
            valid_buys["adj_vwap"] = valid_buys["vwap"] * (
                valid_buys["adj_close"] / valid_buys["close"]
            )
            trade1 = pd.merge(
                signal_df,
                valid_buys[["symbol", "vwap", "adj_vwap"]],
                on="symbol", how="inner",
            )
            trade1 = trade1.rename(columns={"vwap": "buy_price", "adj_vwap": "buy_adj_price"})
            if trade1.empty:
                continue

            # --- 卖出 (以 VWAP 均价撮合) ---
            sell_mask = self._get_trade_mask([t_sell])
            t_sell_actual = sell_mask[~sell_mask["is_limit_down"]].copy()
            t_sell_actual["adj_vwap"] = t_sell_actual["vwap"] * (
                t_sell_actual["adj_close"] / t_sell_actual["close"]
            )
            delayed_symbols = sell_mask[sell_mask["is_limit_down"]]["symbol"].tolist()

            trade2 = pd.merge(
                trade1,
                t_sell_actual[["symbol", "vwap", "adj_vwap"]],
                on="symbol", how="left",
            )
            trade2 = trade2.rename(columns={"vwap": "sell_price", "adj_vwap": "sell_adj_price"})
            trade2["sell_date"] = t_sell

            # --- 延迟卖出 ---
            trade2 = self._handle_delayed_sells(trade2, delayed_symbols, t_sell, ym, t_buy)

            # --- 收益率 ---
            trade2["actual_ret"] = (
                trade2["sell_adj_price"] / trade2["buy_adj_price"]
            ) * (1 - commission) - 1

            # --- IC / RankIC ---
            ic_rec = self._compute_period_ic(trade2, target_factor, ym)
            if ic_rec:
                ic_records.append(ic_rec)

            holding_period_returns.append(trade2)

        return holding_period_returns, ic_records

    def _handle_delayed_sells(self, trade2, delayed_symbols, t_sell, ym, t_buy):
        """
        处理跌停导致的延迟卖出逻辑 (Delayed Exit Logic)

        逻辑说明:
            1. 识别跌停: 在预定卖出日 `t_sell` 处于一字跌停且无成交的标的被标记为 `delayed_symbols`。
            2. 顺延搜索: 仿真引擎会在未来 5 个交易日内搜索首个“打开跌停”的日期（非一字跌停且有成交量）。
            3. 成交价格: 在解板日以当日 **VWAP** 均价进行清仓。
            4. 极端退出: 若未来 5 个交易日均无法卖出（通常见于复牌后连续跌停或退市），
               则在第 5 个交易日强制以当日 VWAP 结转（极端流动性缺失模拟）。
            5. 退市清算: 若依然无法获取价格，则采取惩罚性定价，以买入价的 50% 强制结转（模拟退市损毁）。

        参数:
            trade2 (pd.DataFrame): 当期初始交易记录。
            delayed_symbols (list): 跌停标的代码列表。
            t_sell (Timestamp): 预定卖出日。
            ym (period): 当前月份。
            t_buy (Timestamp): 当期买入日。

        返回:
            pd.DataFrame: 更新了卖出价格与日期的交易表。
        """
        if delayed_symbols:
            future_dates = self.trade_dates[self.trade_dates > t_sell][:5]
            if len(future_dates) > 0:
                future_df = self.limit_df[
                    (self.limit_df["symbol"].isin(delayed_symbols))
                    & (self.limit_df["date"].isin(future_dates))
                ].copy()
                if not future_df.empty:
                    future_df["can_sell"] = (~future_df["is_limit_down"]) & (future_df["vol"] > 0)
                    # 计算复权 VWAP
                    future_df["adj_vwap"] = future_df["vwap"] * (
                        future_df["adj_close"] / future_df["close"]
                    )
                    first_sell = (
                        future_df[future_df["can_sell"]]
                        .sort_values("date").groupby("symbol").first().reset_index()
                    )
                    if not first_sell.empty:
                        update_cols = ["symbol", "vwap", "adj_vwap", "date"]
                        renames = {"vwap": "sell_price", "adj_vwap": "sell_adj_price", "date": "sell_date"}
                        fsu = first_sell[update_cols].rename(columns=renames)
                        fsu.set_index("symbol", inplace=True)
                        trade2.set_index("symbol", inplace=True)
                        trade2.update(fsu)
                        trade2.reset_index(inplace=True)
                        self.logger.debug(f"{ym} {len(first_sell)} 只股票卖出顺延成功")

        # 极端退出: 5个交易日(一周)仍无法卖出
        drop_mask = trade2["sell_adj_price"].isna()
        if drop_mask.sum() > 0:
            self.logger.warning(
                f"当期 {ym}: {drop_mask.sum()} 笔标的极端出局失败, 强制以最后一日 VWAP 结转"
            )
            delayed_extreme = trade2[drop_mask]["symbol"].tolist()
            future_ext = self.trade_dates[self.trade_dates > t_sell][:5]
            if len(future_ext) > 0:
                last_date = future_ext[-1]
                me = self.df_daily[
                    (self.df_daily["symbol"].isin(delayed_extreme))
                    & (self.df_daily["date"] == last_date)
                ].copy()
                if not me.empty:
                    # 极端退出也以 VWAP 撮合
                    me["adj_vwap"] = me["vwap"] * (me["adj_close"] / me["close"])
                    renames = {"vwap": "sell_price", "adj_vwap": "sell_adj_price", "date": "sell_date"}
                    eu = me[["symbol", "vwap", "adj_vwap", "date"]].rename(columns=renames)
                    eu.set_index("symbol", inplace=True)
                    trade2.set_index("symbol", inplace=True)
                    trade2.update(eu)
                    trade2.reset_index(inplace=True)

        # 退市止损
        still_drop = trade2["sell_adj_price"].isna()
        if still_drop.sum() > 0:
            trade2.loc[still_drop, "sell_adj_price"] = trade2.loc[still_drop, "buy_adj_price"] * 0.5
            self.logger.error(f"极端退市清算: {still_drop.sum()} 只标的以买入价50%强制结转")

        return trade2

    def _compute_period_ic(self, trade2, target_factor, ym):
        """
        计算单期信息系数 (Information Coefficient)

        衡量因子得分对未来一段时期收益率的预测能力。
        - Pearson IC: 原始值的线性相关性。
        - Spearman Rank IC: 排名值的秩相关性，对离群值更鲁棒。

        调用示例:
            >>> ic_results = self._compute_period_ic(trade_df, "alpha_factor", pd.Period("2023-01"))

        参数:
            trade2 (pd.DataFrame): 合并了未来真实收益的单期交易表。
            target_factor (str): 因子列名。
            ym (period): 当前月份。

        返回:
            dict: 包含 ['year_month', 'ic', 'rank_ic'] 的字典。
        """
        valid = trade2.dropna(subset=[target_factor, "actual_ret"]).copy()
        valid[target_factor] = pd.to_numeric(valid[target_factor], errors="coerce")
        valid["actual_ret"] = pd.to_numeric(valid["actual_ret"], errors="coerce")
        valid = valid.dropna(subset=[target_factor, "actual_ret"])
        if len(valid) > 10:
            rank_ic, _ = spearmanr(valid[target_factor].values, valid["actual_ret"].values)
            ic, _ = pearsonr(valid[target_factor].values, valid["actual_ret"].values)
            return {"year_month": ym, "ic": ic, "rank_ic": rank_ic}
        return None

    def _compute_group_returns(self, holding_period_returns):
        """
        步骤6: 聚合各分组等权表现与基准推演

        逻辑说明:
            1. 收益聚类: 将所有历史调仓期的交易记录合并，并按 [月份, 组别] 计算算术平均收益。
            2. 净值推演: 为每个分组计算全历史的累计净值曲线 (Cumulative Return)。
            3. 基准对齐: 确保每条曲线都有对应的初始基准点 (Init NV = 1.0)。
            4. 市场组合: 同时计算全市场等权组合的月度收益，作为最基础的参照系。

        参数:
            holding_period_returns (list): 包含每期交易详情 DataFrame 的列表。

        返回:
            tuple: (全量交易表, 各组月度收益净值表, 市场等权收益表, 初始月份)
        """
        df_trades = pd.concat(holding_period_returns, ignore_index=True)
        df_trades = df_trades.dropna(subset=["group"])
        df_trades["group"] = df_trades["group"].astype(int)

        grouped_returns = (
            df_trades.groupby(["year_month", "group"])["actual_ret"]
            .mean().reset_index()
        )
        grouped_returns = grouped_returns.sort_values(["group", "year_month"])
        grouped_returns["净值"] = grouped_returns.groupby("group")[
            "actual_ret"
        ].transform(lambda x: (1 + x).cumprod())

        first_ym = grouped_returns["year_month"].min()
        init_ym = first_ym - 1
        init_rows = [
            {"year_month": init_ym, "group": int(g), "actual_ret": 0.0, "净值": 1.0}
            for g in grouped_returns["group"].unique()
        ]
        grouped_returns = (
            pd.concat([pd.DataFrame(init_rows), grouped_returns], ignore_index=True)
            .sort_values(["group", "year_month"]).reset_index(drop=True)
        )
        grouped_returns["actual_ret"] = grouped_returns["actual_ret"].astype(float)
        grouped_returns["净值"] = grouped_returns["净值"].astype(float)
        grouped_returns["group"] = grouped_returns["group"].astype(int)

        market_returns = df_trades.groupby("year_month")["actual_ret"].mean().reset_index()
        market_returns = market_returns.sort_values("year_month")
        market_returns["市场组合净值"] = (1 + market_returns["actual_ret"]).cumprod()
        market_init = pd.DataFrame(
            [{"year_month": init_ym, "actual_ret": 0.0, "市场组合净值": 1.0}]
        )
        market_returns = (
            pd.concat([market_init, market_returns], ignore_index=True)
            .sort_values("year_month").reset_index(drop=True)
        )
        market_returns["actual_ret"] = market_returns["actual_ret"].astype(float)
        market_returns["市场组合净值"] = market_returns["市场组合净值"].astype(float)

        return df_trades, grouped_returns, market_returns, init_ym

    def _detect_direction(self, grouped_returns, max_group, direction):
        """
        步骤7: 因子多空方向自动判定

        逻辑说明:
            1. 自动探测: 当 `direction='auto'` 时，比较 G1 (最小值组) 与 G10 (最大值组) 的全期终端累计净值。
               - 若 G10 > G1，则判定为正相关 (Long G10)。
               - 若 G1 > G10，则判定为负相关 (Long G1)。
            2. 手动覆盖: 若用户显式指定了方向 (1 或 -1)，则跳过探测逻辑。
            3. 锁定极值组: 确定最优组 (best_g) 与最差组 (worst_g) 的索引。

        参数:
            grouped_returns (pd.DataFrame): 各组绩效汇总。
            max_group (int): 总组数。
            direction: 预设方向。

        返回:
            tuple: (best_g, worst_g, 最终 direction)
        """
        if direction == "auto":
            g1_f = (1 + grouped_returns.loc[grouped_returns["group"] == 1, "actual_ret"]).prod()
            gmax_f = (1 + grouped_returns.loc[grouped_returns["group"] == max_group, "actual_ret"]).prod()
            direction = 1 if gmax_f >= g1_f else -1
            self.logger.info(
                f"多空方向自动判定: {'多G' + str(max_group) if direction == 1 else '多G1'}"
            )
        best_g, worst_g = (max_group, 1) if direction == 1 else (1, max_group)
        return best_g, worst_g, direction

    def _align_benchmark(self, df, df_bench_m):
        """
        步骤8: 基准收益对齐与超额收益 (Alpha) 计算

        计算逻辑:
            Excess Return = Portfolio Return - Benchmark Return
            Excess Cumulative = Π(1 + Excess Return)

        参数:
            df (pd.DataFrame): 组合月度收益序列。
            df_bench_m (pd.DataFrame): 基准指数月度收益序列。

        返回:
            pd.DataFrame: 增加了超额收益列的序列。
        """
        df = pd.merge(df, df_bench_m, on="year_month", how="left").fillna(0)
        df["actual_ret"] = df["actual_ret"].astype(float)
        df["净值"] = df["净值"].astype(float)
        df["bench_return"] = df["bench_return"].astype(float)
        df["excess_ret"] = df["actual_ret"] - df["bench_return"]
        df["excess_cum"] = (1 + df["excess_ret"]).cumprod()
        return df

